{
  "name": "yuei-kendo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 3000 --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "ng build --base-href /yuei-kendo/ && cp dist/yuei-kendo/browser/index.csr.html dist/yuei-kendo/browser/index.html && cp dist/yuei-kendo/browser/index.csr.html dist/yuei-kendo/browser/404.html && touch dist/yuei-kendo/browser/.nojekyll && gh-pages -d dist/yuei-kendo/browser -t"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-server": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@angular/ssr": "^21.2.17",
    "@tailwindcss/postcss": "^4.3.2",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@types/node": "^20.17.19",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
